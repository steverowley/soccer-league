{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "match-sprites/**",
              "tweaks-panel.jsx",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--isl-astro-explorer",
      "--isl-bg",
      "--isl-body",
      "--isl-border",
      "--isl-border-faint",
      "--isl-cta",
      "--isl-fg",
      "--isl-fg-faint",
      "--isl-fg-muted",
      "--isl-focus",
      "--isl-font-grotesk",
      "--isl-font-mono",
      "--isl-galactic-abyss",
      "--isl-glow-cta",
      "--isl-glow-light",
      "--isl-glow-live",
      "--isl-glow-purple",
      "--isl-glow-purple-far",
      "--isl-gutter",
      "--isl-h1",
      "--isl-h2",
      "--isl-h3",
      "--isl-label",
      "--isl-live",
      "--isl-lunar-dust",
      "--isl-micro",
      "--isl-phobos-ash",
      "--isl-purple-500",
      "--isl-purple-700",
      "--isl-purple-900",
      "--isl-quantum-purple",
      "--isl-radius",
      "--isl-radius-round",
      "--isl-red-500",
      "--isl-red-700",
      "--isl-red-900",
