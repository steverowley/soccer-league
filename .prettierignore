# ── Prettier ignore ─────────────────────────────────────────────────────────
# WHY: Prettier should not rewrite generated, vendored, or binary content,
# and should leave Supabase migration SQL files alone so their history is
# stable across environments.

# Build output
dist/
coverage/
node_modules/

# Supabase — schema dumps and migrations are either generated or
# historical records that should not be reformatted.
supabase/schema.sql
supabase/seed.sql
supabase/migrations/
supabase/functions/

# Generated types — regenerated via `generate_typescript_types` on every
# schema change, so hand-formatting them is wasted effort.
src/types/database.ts

# Lock files are machine-managed.
package-lock.json

# Images and other binaries.
*.png
*.jpg
*.jpeg
*.svg
